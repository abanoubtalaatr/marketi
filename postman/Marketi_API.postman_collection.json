        {
          "name": "Product Ratings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/products/{{product_id}}/ratings"
          }
        },
        {
          "name": "Delivery Slots",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/delivery-slots"
          }
        },
        {
          "name": "FAQs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/faqs"
          }
        }
      ]
    },
    {
      "name": "Cart & Checkout",
      "item": [
        {
          "name": "View Cart",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"quantity\": 1,\n  \"size\": \"M\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/cart/items"
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/cart/items/1"
          }
        },
        {
          "name": "Place Order (Cash on Delivery)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('order_id', json.data.order.id);",
                  "  if (json.data.order.payment) pm.collectionVariables.set('payment_id', json.data.order.payment.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delivery_address\": \"Riyadh, King Fahd Road, Building 10\",\n  \"delivery_slot_id\": 1,\n  \"notes\": \"Please call before delivery\",\n  \"payment_type\": \"cash_on_delivery\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Place Order (Online - PayPal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('order_id', json.data.order.id);",
                  "  if (json.data.order.payment) pm.collectionVariables.set('payment_id', json.data.order.payment.id);",
                  "  console.log('Payment URL:', json.data.payment_url);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delivery_address\": \"Riyadh, King Fahd Road, Building 10\",\n  \"delivery_slot_id\": 1,\n  \"notes\": \"Online payment\",\n  \"payment_type\": \"online\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Retry Payment Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}/payment/retry"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Order Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/{{order_id}}/cancel"
          }
        }
