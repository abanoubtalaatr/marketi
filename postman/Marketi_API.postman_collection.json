              "raw": "{\n  \"event_type\": \"PAYMENT.CAPTURE.COMPLETED\",\n  \"resource\": {\n    \"custom_id\": \"{{payment_id}}\",\n    \"status\": \"COMPLETED\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/payments/paypal/webhook"
          }
        },
