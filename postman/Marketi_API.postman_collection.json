{
  "info": {
    "name": "Marketi API",
    "description": "Marketi E-Commerce REST API\n\n**Payment Gateway:** PayPal (https://developer.paypal.com)\n\n**Default credentials:**\n- Admin: admin@marketi.com / password\n- Customer: customer@marketi.com / password\n\n**Online payment flow:**\n1. Login as customer → save token\n2. Add items to cart\n3. POST /orders with payment_type=online\n4. Response includes `payment_url` — open PayPal checkout\n5. After payment, PayPal redirects to success URL and captures payment → order `confirmed`\n6. In dev (mock mode): POST /payments/mock/{payment_id}/complete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "product_id", "value": "1" },
    { "key": "order_id", "value": "" },
    { "key": "payment_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"testuser\",\n  \"phone\": \"0599999999\",\n  \"country_phone_code\": \"+966\",\n  \"email\": \"test@marketi.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/register"
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"customer@marketi.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('admin_token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@marketi.com\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Forgot Password (Send OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0511111111\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/forgot-password"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0511111111\",\n  \"otp\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/verify-otp"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0511111111\",\n  \"password\": \"newpassword\",\n  \"password_confirmation\": \"newpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/reset-password"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Home & Catalog",
      "item": [
        {
          "name": "Home",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/home"
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/search?q=headphones",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [{ "key": "q", "value": "headphones" }]
            }
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Category Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/categories/1/products"
          }
        },
        {
          "name": "List Brands",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/brands"
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/products?sort=rating",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [{ "key": "sort", "value": "rating" }]
            }
          }
        },
        {
          "name": "Product Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/products/{{product_id}}"
